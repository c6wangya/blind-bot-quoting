  "rules": [
    {
      "id": "enter-nofrontfabric-top",
      "trigger": "onEnter",
      "when": {
        "field": "topTreatment",
        "in": [
          "OPEN_ROLL",
          "FASCIA",
          "ROUND_FASCIA",
          "VALANCE",
          "HIDDEN_ROLL"
        ]
      },
      "description": "Fascia/valance/open-roll/hidden-roll expose no cassette interior — front fabric locks off (handleTopGroup)",
      "set": {
        "frontFabric": false
      }
    },
    {
      "id": "enter-exposed-hembar-seed",
      "trigger": "onEnter",
      "when": {
        "field": "hembarStyle",
        "in": [
          "STANDARD",
          "INSERT",
          "EXTERNAL_OVAL"
        ]
      },
      "description": "Entering an exposed rail family from a non-exposed one seeds the rail color from the housing color",
      "copy": {
        "hembarColor": "topColor"
      }
    },
    {
      "id": "enter-independent-top-fabric-seed",
      "trigger": "onEnter",
      "when": {
        "field": "topFabricIndependent",
        "truthy": true
      },
      "description": "Independent top fabric starts from the current panel fabric (handleTopFabricIndependent)",
      "copy": {
        "topFabricColor": "fabricColor",
        "topFabricTexture": "fabricTexture",
        "topFabricTexSize": "texSize"
      }
    },
    {
      "id": "round-top-standard-roll",
      "trigger": "always",
      "when": {
        "field": "topTreatment",
        "in": [
          "CASSETTE_ROUND",
          "ROUND_FASCIA"
        ]
      },
      "description": "Round cassette/fascia bans reverse roll (curved profile + reversed winding reads wrong) — roll snaps back",
      "set": {
        "rollDirection": "STANDARD"
      }
    },
    {
      "id": "shared-band-patterns",
      "trigger": "always",
      "when": {
        "field": "bandPatternsShared",
        "truthy": true
      },
      "description": "Shared band patterns drive the sheer band from the opaque/zebra band (setBandPatternsShared)",
      "copy": {
        "sheerBandTexture": "fabricTexture",
        "sheerBandTexSize": "texSize"
      }
    },
    {
      "id": "band-size-narrow",
      "trigger": "always",
      "when": {
        "field": "bandSize",
        "equals": "NARROW_2P4"
      },
      "description": "Band-height preset drives the underlying pitch + solid ratio",
      "set": {
        "bandPitch": 0.105,
        "solidRatio": 0.58
      }
    },
    {
      "id": "band-size-standard",
      "trigger": "always",
      "when": {
        "field": "bandSize",
        "equals": "STANDARD_3"
      },
      "set": {
        "bandPitch": 0.131,
        "solidRatio": 0.58
      }
    },
    {
      "id": "band-size-wide",
      "trigger": "always",
      "when": {
        "field": "bandSize",
        "equals": "WIDE_3P5"
      },
      "set": {
        "bandPitch": 0.153,
        "solidRatio": 0.58
      }
    },
    {
      "id": "sheer-op-very",
      "trigger": "always",
      "when": {
        "field": "sheerBandOpacity",
        "equals": "VERY_SHEER"
      },
      "description": "Sheer-opacity preset drives the derived alpha",
      "set": {
        "sheerOpacity": 0.1
      }
    },
    {
      "id": "sheer-op-25",
      "trigger": "always",
      "when": {
        "field": "sheerBandOpacity",
        "equals": "SHEER_25"
      },
      "set": {
        "sheerOpacity": 0.25
      }
    },
    {
      "id": "sheer-op-40",
      "trigger": "always",
      "when": {
        "field": "sheerBandOpacity",
        "equals": "SHEER_40"
      },
      "set": {
        "sheerOpacity": 0.4
      }
    },
    {
      "id": "sheer-op-55",
      "trigger": "always",
      "when": {
        "field": "sheerBandOpacity",
        "equals": "SHEER_55"
      },
      "set": {
        "sheerOpacity": 0.55
      }
    }
  ],
