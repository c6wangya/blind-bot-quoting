      "optionsWhen": [
        {
          "when": {
            "field": "hembarSystem",
            "equals": "POCKET"
          },
          "allow": [
            "POCKET"
          ]
        },
        {
          "when": {
            "field": "hembarSystem",
            "equals": "WRAPPED"
          },
          "allow": [
            "RECTANGULAR"
          ]
        },
        {
          "when": {
            "field": "hembarSystem",
            "equals": "EXPOSED"
          },
          "allow": [
            "SLIM_FLAT",
            "LARGE_RECTANGULAR",
            "OVAL",
            "ROUND"
          ],
          "fallback": "SLIM_FLAT"
        },
        {
          "when": {
            "field": "hembarSystem",
            "equals": "BLACKOUT"
          },
          "allow": [
            "D30"
          ]
        }
      ],
