  "rules": [
    {
      "id": "enter-dual-reset",
      "trigger": "onEnter",
      "when": {
        "field": "treatmentMode",
        "equals": "DUAL"
      },
      "description": "Switching to Dual resets to the paired-roller baseline (RollerViewer handleTreatmentMode)",
      "set": {
        "topTreatment": "CASSETTE_SQUARE",
        "rollType": "STANDARD",
        "frontFabric": false,
        "dualChainRearSide": "LEFT",
        "cassetteSize": "5",
        "fasciaSize": "5",
        "fabricType": "ROOM_DARKENING",
        "blackoutSystem": false,
        "sideChannels": false,
        "sideChannelSill": false,
        "openness": 1,
        "dualFrontPosition": 0.5
      }
    },
    {
      "id": "enter-valance-front-fabric",
      "trigger": "onEnter",
      "when": {
        "allOf": [
          {
            "field": "topTreatment",
            "equals": "VALANCE"
          },
          {
            "not": {
              "field": "treatmentMode",
              "equals": "DUAL"
            }
          }
        ]
      },
      "description": "Valance is fabric-wrapped by definition — front fabric locks on",
      "set": {
        "frontFabric": true
      }
    },
    {
      "id": "enter-blackout-package",
      "trigger": "onEnter",
      "when": {
        "field": "blackoutSystem",
        "truthy": true
      },
      "description": "Blackout system pulls in blackout fabric, both channels, standard roll, and the D30 rail; rail color follows the channel color",
      "set": {
        "fabricType": "BLACKOUT",
        "sideChannels": true,
        "sideChannelSill": true,
        "rollType": "STANDARD",
        "hembarSystem": "BLACKOUT"
      },
      "copy": {
        "hembarColor": "sideChannelColor"
      }
    },
    {
      "id": "exit-blackout-fabric-drops-system",
      "trigger": "onEnter",
      "when": {
        "not": {
          "field": "fabricType",
          "equals": "BLACKOUT"
        }
      },
      "description": "Moving the fabric off Blackout turns the blackout system off",
      "set": {
        "blackoutSystem": false
      }
    },
    {
      "id": "enter-cordless-grip",
      "trigger": "onEnter",
      "when": {
        "field": "control",
        "equals": "CORDLESS"
      },
      "description": "Cordless defaults the clear pull grip on",
      "set": {
        "hembarGrip": true
      }
    },
    {
      "id": "enter-independent-top-fabric-seed",
      "trigger": "onEnter",
      "when": {
        "field": "topFabricIndependent",
        "truthy": true
      },
      "description": "Independent top fabric starts from the current panel fabric",
      "copy": {
        "topFabricColor": "fabricColor",
        "topFabricTexture": "fabricTexture",
        "topFabricTexSize": "texSize"
      }
    },
    {
      "id": "dual-invariants",
      "trigger": "always",
      "when": {
        "field": "treatmentMode",
        "equals": "DUAL"
      },
      "description": "Dual permanently excludes reverse roll, front fabric, and the channel/blackout package (enforceRollerSideChannelCompatibility)",
      "set": {
        "rollType": "STANDARD",
        "frontFabric": false,
        "blackoutSystem": false,
        "sideChannels": false,
        "sideChannelSill": false
      }
    },
    {
      "id": "blackout-system-rail",
      "trigger": "always",
      "when": {
        "field": "blackoutSystem",
        "truthy": true
      },
      "description": "While the blackout system is on, the rail hardware is always the blackout channel rail (enforce falls any profile back to D30)",
      "set": {
        "hembarSystem": "BLACKOUT"
      }
    },
    {
      "id": "channels-standard-roll",
      "trigger": "always",
      "when": {
        "anyOf": [
          {
            "field": "sideChannels",
            "truthy": true
          },
          {
            "field": "sideChannelSill",
            "truthy": true
          },
          {
            "field": "blackoutSystem",
            "truthy": true
          }
        ]
      },
      "description": "Any channel package needs the fabric on the wall side — reverse roll snaps back",
      "set": {
        "rollType": "STANDARD"
      }
    },
    {
      "id": "channels-wrapped-repair",
      "trigger": "always",
      "when": {
        "allOf": [
          {
            "anyOf": [
              {
                "field": "sideChannels",
                "truthy": true
              },
              {
                "field": "sideChannelSill",
                "truthy": true
              },
              {
                "field": "blackoutSystem",
                "truthy": true
              }
            ]
          },
          {
            "field": "hembarSystem",
            "equals": "WRAPPED"
          }
        ]
      },
      "description": "Wrapped rails cannot run in channels; enforce falls back to the flat exposed rail",
      "set": {
        "hembarSystem": "EXPOSED",
        "hembarFinish": "INTEGRATED_ENDS",
        "hembarShape": "SLIM_FLAT"
      }
    },
    {
      "id": "blackout-hembar-trio",
      "trigger": "always",
      "when": {
        "field": "hembarSystem",
        "equals": "BLACKOUT"
      },
      "description": "The blackout rail is exactly the channel-seal D30 (enforceRollerHembarCompatibility)",
      "set": {
        "hembarFinish": "CHANNEL_SEAL",
        "hembarShape": "D30"
      }
    },
    {
      "id": "blackout-seal-defaults-brush",
      "trigger": "always",
      "when": {
        "allOf": [
          {
            "field": "hembarSystem",
            "equals": "BLACKOUT"
          },
          {
            "field": "hembarSeal",
            "equals": "NONE"
          }
        ]
      },
      "set": {
        "hembarSeal": "BRUSH"
      }
    },
    {
      "id": "non-blackout-clears-seal",
      "trigger": "always",
      "when": {
        "allOf": [
          {
            "not": {
              "field": "hembarSystem",
              "equals": "BLACKOUT"
            }
          },
          {
            "not": {
              "field": "hembarSeal",
              "equals": "NONE"
            }
          }
        ]
      },
      "set": {
        "hembarSeal": "NONE"
      }
    },
    {
      "id": "grip-unavailable-clears",
      "trigger": "always",
      "when": {
        "anyOf": [
          {
            "not": {
              "field": "control",
              "equals": "CORDLESS"
            }
          },
          {
            "field": "hembarSystem",
            "equals": "POCKET"
          },
          {
            "field": "hembarShape",
            "equals": "ROUND"
          }
        ]
      },
      "description": "rollerHembarGripAvailable: grip exists only on cordless, non-pocket, non-round rails",
      "set": {
        "hembarGrip": false
      }
    }
  ],
